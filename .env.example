# Standalone Docker setup — copy this to .env and fill in values.
# .env is in .gitignore; never commit real credentials.

# ── Headless ADE authorization (Strategy 2) ──────────────────────────────────
# Set both to authorize ADE without a GUI on first run.
# Leave empty if you prefer interactive auth or a snapshot restore.
ADOBE_EMAIL=
ADOBE_PASSWORD=

# ── Wineprefix snapshot restore (Strategy 1) ─────────────────────────────────
# Path inside the container to a .tar.gz snapshot, or an https:// URL.
# If set and volumes/wineprefix is empty, the tarball is extracted on first run.
# Create with: tar -czf wineprefix-authorized.tar.gz -C volumes wineprefix/
# Then either:
#   - mount the file and set a container path:
#       WINEPREFIX_SNAPSHOT=/snapshot/wineprefix-authorized.tar.gz
#   - or serve it over HTTPS and set the URL directly:
#       WINEPREFIX_SNAPSHOT=https://nas.local/backups/wineprefix-authorized.tar.gz
WINEPREFIX_SNAPSHOT=
